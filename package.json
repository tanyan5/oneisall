{
  "name": "oneisall",
  "version": "1.1.0",
  "description": "Windows system toolbox with pluggable tools",
  "main": "./out/main/index.js",
  "author": "tanyan",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "npm run build && electron-builder",
    "pack": "npm run build && electron-builder --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@mohtasham/md-to-docx": "^2.12.3",
    "better-sqlite3": "^11.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.3",
    "vite": "^5.4.14"
  },
  "build": {
    "appId": "com.oneisall.toolbox",
    "productName": "OneIsAll",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "plugins/**/*"
    ],
    "extraResources": [
      {
        "from": "plugins",
        "to": "plugins",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/nav",
        "to": "nav",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/tray",
        "to": "tray",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources",
        "to": ".",
        "filter": [
          "promo.json",
          "announcements.json",
          "icon.ico"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "resources/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
